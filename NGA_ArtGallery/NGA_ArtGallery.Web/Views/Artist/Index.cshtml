@model NGA_ArtGallery.Data.Entities.Artist

<div class="d-flex justify-content-between align-items-center mt-4">
    <h2>@Model.Name's Dashboard</h2>
    <div>
        <a asp-action="EditProfile" asp-route-artistId="@Model.ArtistID" class="btn btn-outline-secondary">Manage Profile</a>
        <a asp-action="Upload" asp-route-artistId="@Model.ArtistID" class="btn btn-primary">Upload New Art</a>
    </div>
</div>

<hr />

<div class="card mb-4 bg-light border-0 shadow-sm">
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <h5>Biography</h5>
                <p>@(string.IsNullOrEmpty(Model.Biography) ? "No biography added yet." : Model.Biography)</p>
            </div>
            <div class="col-md-4 border-start">
                <p><strong>Nationality:</strong> @(Model.Nationality ?? "N/A")</p>
                <p><strong>Birth Date:</strong> @(Model.BirthDate?.ToShortDateString() ?? "N/A")</p>
                <p><strong>Contact:</strong> @(Model.ContactInformation ?? "N/A")</p>
            </div>
        </div>
    </div>
</div>

<h4>Gallery</h4>

@if (Model.Artworks == null || !Model.Artworks.Any())
{
    <div class="py-5 border-2 border-dashed rounded text-center text-muted">
        <p>No artwork uploaded yet.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model.Artworks)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@item.ImageURL" style="height: 180px; object-fit: cover;" class="card-img-top" />
                    <div class="card-body p-2">
                        <p class="mb-0"><strong>@item.Title</strong></p>
                        <p class="text-muted small mb-0">@item.Medium</p>
                    </div>
                    <div class="card-footer p-0 border-top-0">
                        <div class="btn-group w-100">
                            <a asp-action="EditArtwork" asp-route-id="@item.ArtworkID" class="btn btn-warning btn-sm rounded-0">Edit</a>

                            <form asp-action="Delete" asp-route-id="@item.ArtworkID" method="post"
                                  onsubmit="return confirm('Permanently delete?');" class="flex-grow-1">
                                <button type="submit" class="btn btn-danger btn-sm w-100 rounded-0">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}