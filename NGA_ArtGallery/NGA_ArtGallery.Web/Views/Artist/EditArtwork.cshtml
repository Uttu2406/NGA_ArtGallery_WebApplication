@model NGA_ArtGallery.Data.Entities.Artwork

@{
    ViewData["Title"] = "Edit Artwork";
    // Check if current user is Admin to decide where "Cancel" goes
    var cancelRoute = User.IsInRole("Admin") ? new { artistId = Model.ArtistID } : null;
}

<div class="container mt-4">
    <h2>Edit Artwork</h2>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="EditArtwork" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="ArtworkID" />
                <input type="hidden" asp-for="ArtistID" />

                <div class="form-group mb-3">
                    <label asp-for="Title" class="fw-bold"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Medium" class="fw-bold"></label>
                    <input asp-for="Medium" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CreationDate" class="fw-bold">Date Created</label>
                    <input asp-for="CreationDate" type="date" class="form-control" />
                    <span asp-validation-for="CreationDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="fw-bold">About the Piece</label>
                    <textarea asp-for="Description" class="form-control" rows="4">@Model.Description</textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold">Current Image</label><br />
                    <img src="@Model.ImageURL" class="img-thumbnail" style="width: 200px; margin-bottom: 10px;" />
                    <br />
                    <label class="fw-bold">Replace Image (Optional)</label>
                    <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                    <small class="text-muted">Leave empty to keep current image.</small>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success px-4">Update Artwork</button>
                    <a asp-action="Index" asp-all-route-data="@(new Dictionary<string, string> { { "artistId", Model.ArtistID.ToString() } })" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}