@model NGA_ArtGallery.Data.Entities.Artwork

@{
    ViewData["Title"] = "Edit Artwork";
}

<h2>Edit Artwork</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="EditArtwork" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="ArtworkID" />
            <input type="hidden" asp-for="ArtistID" />

            <div class="form-group mb-3">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Medium"></label>
                <input asp-for="Medium" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="CreationDate">Date Created</label>
                <input asp-for="CreationDate" type="date" class="form-control" />
                <span asp-validation-for="CreationDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description">About the Piece</label>
                <textarea asp-for="Description" class="form-control" rows="4">@Model.Description</textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label>Current Image</label><br />
                <img src="@Model.ImageURL" style="width: 200px; border-radius: 4px; margin-bottom: 10px;" />
                <br />
                <label>Replace Image (Optional)</label>
                <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <small class="text-muted">Leave empty to keep current image.</small>
            </div>

            <button type="submit" class="btn btn-success">Update Artwork</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}