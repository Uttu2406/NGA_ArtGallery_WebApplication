@model NGA_ArtGallery.Data.Entities.Artwork

@{
    ViewData["Title"] = "Upload Artwork";
}

<h2>Upload New Artwork</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Upload" method="post" enctype="multipart/form-data">
            <div class="form-group mb-3">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Medium"></label>
                <input asp-for="Medium" class="form-control" placeholder="e.g. Oil on Canvas" />
            </div>

            <div class="form-group mb-3">
                <label>Artwork Image</label>
                <input type="file" name="imageFile" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-success">Post Artwork</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>@*
