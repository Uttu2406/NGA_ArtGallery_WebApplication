@model NGA_ArtGallery.Data.Entities.Artwork

@{
    ViewData["Title"] = "Upload Artwork";
}

<div class="container mt-4">
    <h2>Upload New Artwork</h2>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" name="targetArtistId" value="@ViewBag.TargetArtistId" />

                <div class="form-group mb-3">
                    <label asp-for="Title" class="fw-bold"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Medium" class="fw-bold"></label>
                    <input asp-for="Medium" class="form-control" placeholder="e.g. Oil on Canvas" />
                    <span asp-validation-for="Medium" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CreationDate" class="fw-bold">Date Created</label>
                    <input asp-for="CreationDate" type="date" class="form-control" />
                    <span asp-validation-for="CreationDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="fw-bold">Description / Story</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Tell the story behind this work..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold">Artwork Image</label>
                    <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" required />
                    <span class="text-danger">@Html.ValidationMessage("imageFile")</span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success px-4">Post Artwork</button>
                    <a asp-action="Index" asp-route-artistId="@ViewBag.TargetArtistId" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}