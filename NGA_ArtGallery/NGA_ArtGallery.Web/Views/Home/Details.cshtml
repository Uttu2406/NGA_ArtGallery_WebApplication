@model NGA_ArtGallery.Data.Entities.Artwork

<div class="container mt-5">
    <div class="row">
        <div class="col-md-7">
            <img src="@Model.ImageURL" class="img-fluid rounded shadow" alt="@Model.Title" />
        </div>

        <div class="col-md-5">
            <h1 class="display-5">@Model.Title</h1>
            <p class="text-muted">@Model.Medium</p>
            <hr />

            @if (Model.Artist != null)
            {
                <h4>Artist: @Model.Artist.Name</h4>
                <p><strong>Nationality:</strong> @(Model.Artist.Nationality ?? "Unknown")</p>
                <p><strong>About the Artist:</strong></p>
                <p class="fst-italic">@(Model.Artist.Biography ?? "This artist hasn't shared a biography yet.")</p>
            }

            <div class="mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary">Back to Gallery</a>
            </div>
        </div>
    </div>
</div>