@model IEnumerable<NGA_ArtGallery.Data.Entities.Artwork>

<div style="text-align: center; margin-bottom: 30px;">
    <h1>NGA Public Gallery</h1>
    <p>Viewing all current exhibits</p>
</div>

@if (!Model.Any())
{
    <div style="text-align: center; padding: 50px; color: #888;">
        <h3>The gallery is currently empty.</h3>
        <p>Our artists are currently preparing new masterpieces!</p>
    </div>
}
else
{
    <div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;">
        @foreach (var item in Model)
        {
            <div style="border: 1px solid #ccc; width: 300px; padding: 10px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                <a asp-controller="Home" asp-action="Details" asp-route-id="@item.ArtworkID" style="text-decoration: none; color: inherit;">
                    <img src="@item.ImageURL" alt="@item.Title" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px; cursor: pointer;" />

                    <h3 style="margin: 10px 0 5px 0;">@item.Title</h3>
                </a>

                <p style="color: #666; font-size: 0.9em; margin-bottom: 15px;">
                    <strong>Artist:</strong> @(item.Artist?.Name ?? "Anonymous")<br />
                    <strong>Medium:</strong> @item.Medium
                </p>

                <a asp-controller="Home" asp-action="Details" asp-route-id="@item.ArtworkID"
                   class="btn btn-sm btn-outline-primary" style="width: 100%;">
                    View Masterpiece
                </a>
            </div>
        }
    </div>
}